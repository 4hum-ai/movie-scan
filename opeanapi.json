{
  "openapi": "3.1.0",
  "info": {
    "version": "0.1.0"
  },
  "paths": {
    "/get_token": {
      "post": {
        "tags": ["auth"],
        "summary": "Get Token",
        "description": "Handles the generation and retrieval of an access token based on the credentials\nand client identification provided through the request. The endpoint is secured\nand validates the access key against a predefined secret key. If the validation\nis successful, an access token is generated with a specified expiration period\ndefined in the application settings.\n\n:return: A response containing the original request data and the generated\n    access token.\n\n:raises HTTPException: If the provided access key does not match the secret key,\n    a 401 Unauthorized status is raised with a \"Bearer\" authentication header.",
        "operationId": "get_token_get_token_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/GetTokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetTokenResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["server_info"],
        "summary": "Health Check",
        "description": "Health check endpoint",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1.0/sync/analyze": {
      "post": {
        "tags": [],
        "summary": "Video Content Analyze",
        "description": "Processes a video content analysis request by reading the uploaded video file, saving it temporarily\nto the filesystem, validating its size, and analyzing its content. Returns the video analysis result\nor raises exceptions in case of errors during file handling, validation, or analysis.\n\n:raises HTTPException: Raised with status code 500 if there are issues in file handling, such as\n    file access errors, exceeding the file size limit, or video analysis engine errors.\n\n:raises InputFileException: Raised if the input file exceeds the allowed size limit.",
        "operationId": "video_content_analyze_api_v1_0_sync_analyze_post",
        "parameters": [
          {
            "name": "x-access-token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "An access token. Obtained by calling to /get_token",
              "title": "X-Access-Token"
            },
            "description": "An access token. Obtained by calling to /get_token"
          },
          {
            "name": "clientId",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Client ID. A string to identify the client. Must be the same as clientId in the Request body",
              "title": "Clientid"
            },
            "description": "Client ID. A string to identify the client. Must be the same as clientId in the Request body"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/VideoAnalysisRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoAnalysisResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
